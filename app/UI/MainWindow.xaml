<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Watchdog v1.0 - Command Center" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen" Background="#0D1117" Foreground="#C9D1D9"
        FontFamily="Segoe UI Semibold">
    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBg" Color="#161B22"/>
        <SolidColorBrush x:Key="CardBg" Color="#0D1117"/>
        <SolidColorBrush x:Key="AccentCyan" Color="#58A6FF"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#BC8CFF"/>
        <SolidColorBrush x:Key="CriticalRed" Color="#FF7B72"/>
        <SolidColorBrush x:Key="HighOrange" Color="#FFA657"/>
        <SolidColorBrush x:Key="TextMain" Color="#C9D1D9"/>
        <SolidColorBrush x:Key="TextDim" Color="#8B949E"/>
        <SolidColorBrush x:Key="CardBorder" Color="#30363D"/>
        
        <Style TargetType="Button">
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#161B22"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
        </Style>
        <Color x:Key="AccentCyanColor">#58A6FF</Color>
        <SolidColorBrush x:Key="StatusGreen" Color="#238636"/>
        <VisualBrush x:Key="ScanlineBrush" TileMode="Tile" Viewport="0,0,1,4" ViewportUnits="Absolute">
            <VisualBrush.Visual>
                <Line X1="0" Y1="0" X2="1" Y2="0" Stroke="Black" StrokeThickness="1" Opacity="0.1"/>
            </VisualBrush.Visual>
        </VisualBrush>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR NAVIGATION -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="32,48,32,32">
                    <StackPanel>
                        <Image x:Name="LogoImage" Source="logo.png" Height="240" Width="240" Margin="0,0,0,32" HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <ScaleTransform x:Name="LogoScale" ScaleX="1" ScaleY="1"/>
                            </Image.RenderTransform>
                            <Image.Effect>
                                <DropShadowEffect Color="#58A6FF" BlurRadius="25" Opacity="0.6" ShadowDepth="0"/>
                            </Image.Effect>
                            <Image.Triggers>
                                <EventTrigger RoutedEvent="Image.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleX" From="1.0" To="1.08" Duration="0:0:1.5" AutoReverse="True" RepeatBehavior="Forever"/>
                                            <DoubleAnimation Storyboard.TargetName="LogoScale" Storyboard.TargetProperty="ScaleY" From="1.0" To="1.08" Duration="0:0:1.5" AutoReverse="True" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Image.Triggers>
                        </Image>
                        <TextBlock Text="AI WATCHDOG v1.0" FontSize="24" FontWeight="Black" Foreground="{StaticResource AccentCyan}"/>
                        <Border Background="#15FFFFFF" CornerRadius="8" Padding="12,6" HorizontalAlignment="Left" Margin="0,12,0,0">
                            <TextBlock Text="Powered by Gemma 4" FontSize="14" Foreground="#FFFFFF" FontWeight="Bold">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="25" Color="#FFFFFF" ShadowDepth="0" Opacity="1.0"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom" Padding="32" Background="#0D1117">
                    <StackPanel>
                        <TextBlock Text="Affordable Cybersecurity" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentPurple}"/>
                        <TextBlock Text="For Every Small Business Organization" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextDim}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <ListBox x:Name="NavList" Background="Transparent" BorderThickness="0" Margin="0,20" SelectedIndex="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="32,16"/>
                            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder" Background="Transparent" BorderThickness="4,0,0,0" BorderBrush="Transparent">
                                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#21262D"/>
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentCyan}"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentCyan}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBoxItem Content="SECURITY OPERATIONS CENTER"/>
                    <ListBoxItem Content="INCIDENTS"/>
                    <ListBoxItem Content="COLLECTORS"/>
                    <ListBoxItem Content="MONITOR"/>
                    <ListBoxItem Content="REPORTS"/>
                    <ListBoxItem Content="SETTINGS"/>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Background="{StaticResource SidebarBg}" BorderBrush="{StaticResource CardBorder}" BorderThickness="0,0,0,1" Padding="40,0">
                <DockPanel>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="PageSubtitle" Text="Security Operations Center" FontSize="20" FontWeight="Black" Foreground="{StaticResource TextMain}"/>
                        <TextBlock Text="GEMMA 4 - POWERED SOC MONITORING SYSTEM" Foreground="{StaticResource TextDim}" FontSize="11" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#1A238636" BorderBrush="{StaticResource StatusGreen}" BorderThickness="1" CornerRadius="4" Padding="12,6">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{StaticResource StatusGreen}" Margin="0,0,8,0">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Ellipse.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.3" To="1.0" Duration="0:0:1" AutoReverse="True" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="SYSTEM OPERATIONAL" Foreground="{StaticResource StatusGreen}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- VIEW CONTAINER -->
            <Grid Grid.Row="1" Margin="40">
                
                <!-- 1. DASHBOARD VIEW -->
                <Grid x:Name="DashboardView" Visibility="Visible">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <UniformGrid Columns="4" Rows="2" Margin="0,0,0,32">
                                <Border Background="{StaticResource CardBg}" Margin="8" CornerRadius="12" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="24">
                                    <StackPanel><TextBlock Text="EVENTS TODAY" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}"/><TextBlock x:Name="KpiEventsToday" Text="0" FontSize="36" FontWeight="Black" Margin="0,12,0,0"/></StackPanel>
                                </Border>
                                <Border Background="{StaticResource CardBg}" Margin="8" CornerRadius="12" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="24">
                                    <StackPanel><TextBlock Text="CRITICAL ALERTS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}"/><TextBlock x:Name="KpiCriticalAlerts" Text="0" FontSize="36" FontWeight="Black" Foreground="{StaticResource CriticalRed}" Margin="0,12,0,0"/></StackPanel>
                                </Border>
                                <Border Background="{StaticResource CardBg}" Margin="8" CornerRadius="12" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="24">
                                    <StackPanel><TextBlock Text="HIGH ALERTS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}"/><TextBlock x:Name="KpiHighAlerts" Text="0" FontSize="36" FontWeight="Black" Foreground="{StaticResource HighOrange}" Margin="0,12,0,0"/></StackPanel>
                                </Border>
                                <Border Background="{StaticResource CardBg}" Margin="8" CornerRadius="12" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="24">
                                    <StackPanel><TextBlock Text="MEDIUM ALERTS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}"/><TextBlock x:Name="KpiMediumAlerts" Text="0" FontSize="36" FontWeight="Black" Foreground="#F2C94C" Margin="0,12,0,0"/></StackPanel>
                                </Border>
                                <Border Background="{StaticResource CardBg}" Margin="8" CornerRadius="12" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="24">
                                    <StackPanel><TextBlock Text="HOSTS MONITORED" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}"/><TextBlock x:Name="KpiHostsMonitored" Text="0" FontSize="36" FontWeight="Black" Margin="0,12,0,0"/></StackPanel>
                                </Border>
                                <Border Background="{StaticResource CardBg}" Margin="8" CornerRadius="12" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="24">
                                    <StackPanel><TextBlock Text="COLLECTOR STATUS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}"/><TextBlock x:Name="KpiCollectorStatus" Text="HEALTHY" FontSize="22" FontWeight="Black" Foreground="#54D685" Margin="0,12,0,0"/></StackPanel>
                                </Border>
                                <Border Background="{StaticResource CardBg}" Margin="8" CornerRadius="12" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="24">
                                    <StackPanel><TextBlock Text="AI DECISIONS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}"/><TextBlock x:Name="KpiAIDecisions" Text="0" FontSize="36" FontWeight="Black" Foreground="{StaticResource AccentPurple}" Margin="0,12,0,0"/></StackPanel>
                                </Border>
                                <Border Background="{StaticResource CardBg}" Margin="8" CornerRadius="12" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="24">
                                    <StackPanel><TextBlock Text="RISK SCORE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDim}"/><TextBlock x:Name="KpiRiskScore" Text="0" FontSize="36" FontWeight="Black" Foreground="{StaticResource AccentCyan}" Margin="0,12,0,0"/></StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>


                <!-- 3. INCIDENTS VIEW -->
                <Grid x:Name="IncidentsView" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="180"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{StaticResource CardBg}" CornerRadius="12" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="20" Margin="0,0,0,12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                                <Button x:Name="GenerateDemoAttackButton" Content="RUN SIMULATION" Margin="10,0,0,0" Background="Blue" Padding="10,4" FontSize="10"/>
                            </StackPanel>
                            <DataGrid x:Name="IncidentsGrid" IsReadOnly="True" AutoGenerateColumns="False" FontSize="11" ColumnWidth="*">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#161B22"/>
                                        <Setter Property="Foreground" Value="{StaticResource AccentCyan}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                        <Setter Property="Padding" Value="4,8"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="TIMESTAMP" Binding="{Binding Time}" Width="150"/>
                                    <DataGridTextColumn Header="SOURCE HOST" Binding="{Binding Host}" Width="120"/>
                                    <DataGridTemplateColumn Header="THREAT LEVEL" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="6" Padding="8,2" HorizontalAlignment="Left" BorderThickness="1" MinWidth="80">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                    <Setter Property="Background" Value="#2A1A1C"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource CriticalRed}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="High">
                                                                    <Setter Property="Background" Value="#2A211A"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource HighOrange}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="Medium">
                                                                    <Setter Property="Background" Value="#2A2A1A"/>
                                                                    <Setter Property="BorderBrush" Value="#F2C94C"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Severity}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                        <Setter Property="Foreground" Value="{StaticResource CriticalRed}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="High">
                                                                        <Setter Property="Foreground" Value="{StaticResource HighOrange}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="Medium">
                                                                        <Setter Property="Foreground" Value="#F2C94C"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                    
                    <Grid Grid.Row="1">
                        <!-- EXPANDED AI SOC ASSISTANT -->
                        <Border Grid.Column="0" Background="{StaticResource CardBg}" CornerRadius="12" BorderBrush="{StaticResource AccentCyan}" BorderThickness="1" Padding="20">
                            <Border.Effect>
                                <DropShadowEffect Color="{StaticResource AccentCyanColor}" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                            </Border.Effect>
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="GEMMA-4 LOCAL AI ANALYSIS ENGINE" FontSize="11" FontWeight="Black" Foreground="{StaticResource AccentCyan}" VerticalAlignment="Center"/>
                                    <!-- RADAR ANIMATION (RED ALERT MODE) -->
                                    <Grid x:Name="RadarGrid" Width="18" Height="18" Margin="10,0,0,0" Visibility="Collapsed" VerticalAlignment="Center">
                                        <Ellipse Stroke="{StaticResource CriticalRed}" StrokeThickness="1" Opacity="0.3"/>
                                        <Path Fill="{StaticResource CriticalRed}" Data="M 9,9 L 9,0 A 9,9 0 0 1 15,3 Z" Opacity="0.8">
                                            <Path.RenderTransform>
                                                <RotateTransform x:Name="RadarRotate" CenterX="9" CenterY="9"/>
                                            </Path.RenderTransform>
                                        </Path>
                                    </Grid>
                                </StackPanel>
                                
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <TextBlock x:Name="AnalysisStatusText" Text="SYSTEM READY" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                    <ProgressBar x:Name="AnalysisProgressBar" Height="4" VerticalAlignment="Bottom" Background="#10FFFFFF" BorderThickness="0" IsIndeterminate="False" Visibility="Collapsed" Foreground="{StaticResource AccentCyan}">
                                        <ProgressBar.Effect>
                                            <DropShadowEffect Color="{StaticResource AccentCyanColor}" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                                        </ProgressBar.Effect>
                                    </ProgressBar>
                                </Grid>

                                <RichTextBox x:Name="AISummaryConsole" IsReadOnly="True" Background="#0D1117" BorderThickness="0" FontFamily="Courier New" FontSize="14" Foreground="#00FF41">
                                    <RichTextBox.Resources>
                                        <Style TargetType="{x:Type Paragraph}">
                                            <Setter Property="Margin" Value="0"/>
                                        </Style>
                                    </RichTextBox.Resources>
                                    <FlowDocument x:Name="ConsoleDoc">
                                        <Paragraph x:Name="ConsoleParagraph"/>
                                    </FlowDocument>
                                </RichTextBox>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- 4. COLLECTORS VIEW -->
                <Grid x:Name="CollectorsView" Visibility="Collapsed">
                    <Border Background="{StaticResource CardBg}" CornerRadius="12" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="32">
                        <DockPanel>
                            <TextBlock Text="MANAGED ENDPOINTS" DockPanel.Dock="Top" FontSize="16" FontWeight="Black" Margin="0,0,0,24"/>
                            <DataGrid x:Name="CollectorsGrid" IsReadOnly="True" AutoGenerateColumns="True" ColumnWidth="*"/>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- 5. REPORTS VIEW -->
                <Grid x:Name="ReportsView" Visibility="Collapsed">
                    <Border Background="{StaticResource CardBg}" CornerRadius="12" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="40">
                        <StackPanel>
                            <TextBlock Text="EXECUTIVE SECURITY REPORTS" FontSize="20" FontWeight="Black" Margin="0,0,0,12"/>
                            <TextBlock Text="Generate mission-critical summaries of recent threat activity." Foreground="{StaticResource TextDim}" Margin="0,0,0,40"/>
                            <UniformGrid Columns="1">
                                <Button x:Name="GenerateHtmlReportButton" Content="EXPORT HTML THREAT REPORT" Height="60" Margin="10"/>
                            </UniformGrid>
                            <TextBlock x:Name="ReportStatusText" Text="Status: Ready" Foreground="{StaticResource AccentCyan}" Margin="10,20,0,0" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 6. SETTINGS VIEW -->
                <Grid x:Name="SettingsView" Visibility="Collapsed">
                    <Border Background="{StaticResource CardBg}" CornerRadius="12" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="40">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="400"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="SCAN INTERVAL (S)" VerticalAlignment="Center" FontWeight="Bold" Margin="0,15"/>
                            <TextBox x:Name="ScanIntervalInput" Grid.Row="0" Grid.Column="1" Margin="0,8" Padding="10" Background="#161B22" Foreground="#FFFFFF"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="AI MODEL VARIANT:" Foreground="{StaticResource TextDim}" VerticalAlignment="Center"/>
                            <TextBox x:Name="AiModelInput" Grid.Row="2" Grid.Column="1" Background="#161B22" Foreground="#FFFFFF" BorderBrush="{StaticResource CardBorder}" Padding="8,4"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="OLLAMA ENDPOINT:" Foreground="{StaticResource TextDim}" VerticalAlignment="Center"/>
                            <TextBox x:Name="ApiEndpointInput" Grid.Row="3" Grid.Column="1" Background="#161B22" Foreground="#FFFFFF" BorderBrush="{StaticResource CardBorder}" Padding="8,4"/>

                            <Button x:Name="SaveSettingsButton" Grid.Row="5" Grid.Column="1" Content="SAVE CONFIGURATION" Margin="0,30,0,0" Background="#238636"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 7. SYSTEM MONITOR VIEW -->
                <Grid x:Name="MonitorView" Visibility="Collapsed">
                    <StackPanel>
                        <UniformGrid Columns="2" Margin="0,0,0,24">
                            <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="12" Margin="8" Padding="32">
                                <StackPanel>
                                    <TextBlock Text="NEURAL CORE LOAD (CPU)" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextDim}" Margin="0,0,0,20"/>
                                    <Grid Height="60">
                                        <ProgressBar x:Name="CpuMeter" Value="0" Maximum="100" Background="#161B22" Foreground="{StaticResource AccentCyan}" BorderThickness="0"/>
                                        <TextBlock x:Name="CpuText" Text="0%" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Black" Foreground="#FFFFFF"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="12" Margin="8" Padding="32">
                                <StackPanel>
                                    <TextBlock Text="MODEL MEMORY (RAM)" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextDim}" Margin="0,0,0,20"/>
                                    <Grid Height="60">
                                        <ProgressBar x:Name="RamMeter" Value="0" Maximum="100" Background="#161B22" Foreground="{StaticResource AccentPurple}" BorderThickness="0"/>
                                        <TextBlock x:Name="RamText" Text="0 GB" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" FontWeight="Black" Foreground="#FFFFFF"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                        <Border Background="{StaticResource CardBg}" CornerRadius="12" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="24">
                            <DataGrid x:Name="MonitorGrid" Height="250" AutoGenerateColumns="True"/>
                        </Border>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
        
        <!-- TOP LEVEL OVERLAYS -->
        <Rectangle Fill="{StaticResource ScanlineBrush}" IsHitTestVisible="False" Opacity="0.5"/>
    </Grid>
</Window>
